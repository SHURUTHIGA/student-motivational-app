{
  "info": {
    "name": "Student Motivation API",
    "_postman_id": "a6e5fc2d-6112-4e68-8f1e-f6657afed9cd",
    "description": "REST API routes for auth, analysis, and teacher records with JWT.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "studentEmail",
      "value": "student1@example.com"
    },
    {
      "key": "studentPassword",
      "value": "test123"
    },
    {
      "key": "studentToken",
      "value": ""
    },
    {
      "key": "teacherToken",
      "value": ""
    },
    {
      "key": "recordId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      }
    },
    {
      "name": "Register Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var res = pm.response.json();",
              "if (res.token) { pm.collectionVariables.set('studentToken', res.token); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var res = pm.response.json();",
              "if (res.token) { pm.collectionVariables.set('studentToken', res.token); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Login Teacher",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var res = pm.response.json();",
              "if (res.token) { pm.collectionVariables.set('teacherToken', res.token); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher@gmail.com\",\n  \"password\": \"teacher123\",\n  \"role\": \"teacher\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Get Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Create Analysis (Student/Teacher Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{studentToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentName\": \"John Student\",\n  \"age\": 19,\n  \"gender\": \"Male\",\n  \"studentClass\": \"BSc IT\",\n  \"section\": \"A\",\n  \"department\": \"Information Technology\",\n  \"semester\": \"3\",\n  \"cgpa\": 8.1,\n  \"studyGoal\": \"Improve consistency\",\n  \"attendanceLevel\": \"good\",\n  \"assignmentStatus\": \"on_track\",\n  \"extracurricularLevel\": \"active\",\n  \"parentSupportLevel\": \"high\",\n  \"stressLevelText\": \"moderate\",\n  \"studyHours\": 3,\n  \"sleepHours\": 7\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/analyses",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "analyses"
          ]
        }
      }
    },
    {
      "name": "List Records (Teacher Token)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/records",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "records"
          ]
        }
      }
    },
    {
      "name": "Get Record By Id (Teacher Token)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/records/{{recordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "records",
            "{{recordId}}"
          ]
        }
      }
    },
    {
      "name": "Update Record By Id (Teacher Token)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentName\": \"Updated Student\",\n  \"department\": \"IT\",\n  \"semester\": \"4\",\n  \"studyHours\": 4,\n  \"sleepHours\": 8,\n  \"attendanceLevel\": \"excellent\",\n  \"assignmentStatus\": \"on_track\",\n  \"stressLevelText\": \"low\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/records/{{recordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "records",
            "{{recordId}}"
          ]
        }
      }
    },
    {
      "name": "Delete Record By Id (Teacher Token)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{teacherToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/records/{{recordId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "records",
            "{{recordId}}"
          ]
        }
      }
    }
  ]
}
